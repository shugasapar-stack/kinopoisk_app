rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function owns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /movies/{movieId} {
      allow read: if true;
      allow create, update: if signedIn();
      allow delete: if false;
    }

    match /users/{uid} {
      allow read, write: if owns(uid);
      match /history/{movieId} {
        allow read, write: if owns(uid);
      }
      match /tasks/{taskId} {
        allow read, write: if owns(uid);
      }
      match /ratings/{movieId} {
        allow read, write: if owns(uid);
      }
      match /private/{documentId} {
        allow read, write: if owns(uid);
      }
    }

    match /favorites/{uid} {
      allow read, write: if owns(uid);
    }

    match /watchlists/{listId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.uid == request.auth.uid;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
